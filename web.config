<?xml version="1.0" encoding="utf-8"?> 
<configuration> 
  <system.webServer> 
    <rewrite> 
      <rules> 
        <rule name="DanabriLocalProxy" stopProcessing="true"> 
          <match url="(.*)" /> 
          <action type="Rewrite" url="http://localhost:3000/{R:1}" appendQueryString="true" /> 
        </rule> 
      </rules> 
    </rewrite> 
  </system.webServer> 
</configuration>